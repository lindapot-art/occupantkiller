# Backend environment template — copy to backend/.env
PORT=3001
DB_PATH=./game.db
ALLOWED_ORIGINS=*
ACTIVE_NETWORK=amoy

# Oracle signing key (MUST match the oracle registered on the deployed contracts)
ORACLE_PRIVATE_KEY=0x...

# CashApp / fiat payments
CASHAPP_TAG=$lindapot
CASHAPP_ADMIN_KEY=change-me-strong-random-key

