# ═══════════════════════════════════════════════════════════════════
#  Occupant Killer — Contracts environment template
#  Copy to contracts/.env and fill in real values. NEVER commit .env.
# ═══════════════════════════════════════════════════════════════════

# Polygon RPC endpoints
AMOY_RPC_URL=https://rpc-amoy.polygon.technology
POLYGON_RPC_URL=https://polygon-rpc.com

# Private keys — 0x-prefixed, 64 hex chars. KEEP SECRET.
DEPLOYER_PRIVATE_KEY=0x...
ORACLE_PRIVATE_KEY=0x...

# Token allocation recipients (use Gnosis Safe multisigs in production)
TREASURY_ADDRESS=0x...
TEAM_ADDRESS=0x...
LIQUIDITY_ADDRESS=0x...
COMMUNITY_ADDRESS=0x...

# NFT metadata base URIs (trailing slash required)
NFT_BASE_URI=https://api.occupantkiller.game/nft/
WEAPONS_BASE_URI=https://api.occupantkiller.game/weapons/

# PolygonScan API key for source verification (optional)
POLYGONSCAN_API_KEY=
